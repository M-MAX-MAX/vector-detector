NODE_ENV=production
PORT=3000

# Required: random string for session cookie signing
JWT_SECRET=change-me-to-a-random-secret

# Optional: MySQL database URL (only needed for user auth/login feature)
# DATABASE_URL=mysql://user:password@host:3306/dbname

# Optional: Manus OAuth (not needed for standalone Railway deployment)
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# VITE_APP_ID=
